generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                 String         @id(map: "Tenant_pkey") @default(cuid())
  name               String
  subdomain          String         @unique(map: "Tenant_subdomain_key")
  status             String         @default("active")
  dbConnectionString String?        @map("db_connection_string")
  planTier           String         @default("standard") @map("plan_tier")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  members            TenantMember[]
  usageLogs          UsageLog[]
  workspaces         Workspace[]
  teams              Team[]
  agents             Agent[]
  positions          Position[]
  phoneNumbers       MemberPhoneNumber[]
  certifications     MemberCertification[]
  education          MemberEducation[]
  skills             MemberSkill[]
  menuConfig         Json?          @map("menu_config")
  branding           Json?
  localization       Json?
  metadata           Json?
  workspaceSettings  Json?          @map("workspace_settings")
  permissionGroups   PermissionGroup[]
  memberPermissionGroups MemberPermissionGroup[]
  auditLogs          AuditLog[]
  parties            Party[]
  partyRelationships PartyRelationship[]
  taxonomies         Taxonomy[]

  @@map("tenants")
}

model UsageLog {
  id        String   @id(map: "UsageLog_pkey") @default(cuid())
  tenantId  String   @map("tenant_id")
  type      String
  amount    Float
  metadata  Json?
  timestamp DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], map: "UsageLog_tenantId_fkey")

  @@index([tenantId, timestamp], map: "UsageLog_tenantId_timestamp_idx")
  @@map("usage_logs")
}

model Workspace {
  id       String   @id(map: "Workspace_pkey") @default(cuid())
  tenantId String   @map("tenant_id")
  name     String
  modules  Module[]
  tenant   Tenant   @relation(fields: [tenantId], references: [id], map: "Workspace_tenantId_fkey")

  @@index([tenantId], map: "Workspace_tenantId_idx")
  @@unique([id, tenantId])
  @@map("workspaces")
}

model Module {
  id          String    @id(map: "Module_pkey") @default(cuid())
  tenantId    String    @map("tenant_id")
  workspaceId String    @map("workspace_id")
  name        String
  config      Json
  createdAt   DateTime  @default(now()) @map("created_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], map: "Module_workspaceId_fkey")
  records     Record[]

  @@index([tenantId], map: "Module_tenantId_idx")
  @@unique([id, tenantId])
  @@map("modules")
}

model User {
  id           String         @id(map: "User_pkey")
  email        String         @unique(map: "User_email_key")
  createdAt    DateTime       @default(now()) @map("created_at")
  isSuperAdmin Boolean        @default(false) @map("is_superadmin")
  updatedAt    DateTime       @default(now()) @updatedAt @map("updated_at")
  memberships  TenantMember[]

  @@map("users")
}

model TenantMember {
  id          String   @id(map: "TenantMember_pkey") @default(cuid())
  userId      String?  @map("user_id")
  agentId     String?  @map("agent_id")
  tenantId    String   @map("tenant_id")
  teamId      String?  @map("team_id")
  roleId      String   @default("Standard") @map("role_id") // Maps to 'Standard', 'Lead', 'Admin'
  positionId  String?  @map("position_id")
  isSynthetic Boolean  @default(false) @map("is_synthetic")
  status      String   @default("Active") @map("status")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  
  tenant      Tenant   @relation(fields: [tenantId], references: [id], map: "TenantMember_tenantId_fkey")
  user        User?    @relation(fields: [userId], references: [id], map: "TenantMember_userId_fkey")
  agent       Agent?   @relation(fields: [agentId], references: [id], map: "TenantMember_agentId_fkey")
  team        Team?    @relation(fields: [teamId], references: [id], map: "TenantMember_teamId_fkey")
  position    Position? @relation(fields: [positionId], references: [id], map: "TenantMember_positionId_fkey")
  menuConfig  Json?    @map("menu_config")

  // Comprehensive Staff Details
  firstName       String?   @map("first_name")
  otherName       String?   @map("other_name")
  familyName      String?   @map("family_name")
  personalEmail   String?   @map("personal_email")
  homeAddress     String?   @map("home_address")
  workArrangements String?   @map("work_arrangements")
  emergencyContact String?   @map("emergency_contact")
  dateOfBirth     DateTime? @map("date_of_birth")
  gender          String?   @map("gender")
  nationality     String?   @map("nationality")
  startDate       DateTime? @map("start_date")
  endDate         DateTime? @map("end_date")
  
  // Workforce Hub Enhancements
  avatarUrl       String?   @map("avatar_url")
  isContractor    Boolean   @default(false) @map("is_contractor")
  licenceType     String    @default("Standard") @map("licence_type")
  aiHumour        Float     @default(0.5) @map("ai_humour")
  workEmail       String?   @map("work_email")
  signature       String?   @map("signature")

  phoneNumbers    MemberPhoneNumber[]
  certifications  MemberCertification[]
  education       MemberEducation[]
  skills          MemberSkill[]
  permissionGroups MemberPermissionGroup[]
  
  // HR & Succession Relations
  successions      MemberSuccession[]
  contracts        EmploymentContract[]
  leaveBalances    LeaveBalance[]
  leaveRequests    LeaveRequest[]
  timesheets       Timesheet[]

  @@unique([userId, tenantId], map: "TenantMember_userId_tenantId_key")
  @@unique([id, tenantId])
  @@index([tenantId], map: "TenantMember_tenantId_idx")
  @@index([userId], map: "TenantMember_userId_idx")
  @@map("tenant_members")
}

model MemberPhoneNumber {
  id        String   @id @default(cuid())
  memberId  String   @map("member_id")
  tenantId  String   @map("tenant_id")
  label     String   // e.g. 'Work', 'Home', 'Mobile'
  number    String
  member    TenantMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("member_phone_numbers")
}

model MemberCertification {
  id            String    @id @default(cuid())
  memberId      String    @map("member_id")
  tenantId      String    @map("tenant_id")
  name          String
  issuer        String?
  dateObtained  DateTime? @map("date_obtained")
  expiryDate    DateTime? @map("expiry_date")
  member        TenantMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("member_certifications")
}

model MemberEducation {
  id            String    @id @default(cuid())
  memberId      String    @map("member_id")
  tenantId      String    @map("tenant_id")
  institution   String
  degree        String?
  fieldOfStudy  String?   @map("field_of_study")
  startDate     DateTime? @map("start_date")
  endDate       DateTime? @map("end_date")
  member        TenantMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("member_education")
}

model MemberSkill {
  id              String   @id @default(cuid())
  memberId        String   @map("member_id")
  tenantId        String   @map("tenant_id")
  name            String
  proficiencyLevel String?  @map("proficiency_level")
  member          TenantMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("member_skills")
}

model Team {
  id          String         @id @default(cuid())
  tenantId    String         @map("tenant_id")
  name        String
  description String?
  avatarUrl   String?        @map("avatar_url")
  createdAt   DateTime       @default(now()) @map("created_at")
  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  members     TenantMember[]

  @@index([tenantId])
  @@unique([id, tenantId])
  @@map("teams")
}

model Agent {
  id          String         @id @default(cuid())
  tenantId    String         @map("tenant_id")
  name        String
  modelType   String         @map("model_type")
  config      Json?
  createdAt   DateTime       @default(now()) @map("created_at")
  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  memberships TenantMember[]

  @@index([tenantId])
  @@unique([id, tenantId])
  @@map("agents")
}

model Record {
  id        String   @id(map: "Record_pkey") @default(cuid())
  tenantId  String   @map("tenant_id")
  moduleId  String   @map("module_id")
  data      Json
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade, map: "Record_moduleId_fkey")

  @@index([moduleId], map: "Record_moduleId_idx")
  @@index([tenantId], map: "Record_tenantId_idx")
  @@map("records")
}

model DocumentTemplate {
  id          String   @id(map: "DocumentTemplate_pkey") @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  moduleId    String?  @map("module_id")
  content     String
  status      String   @default("Draft")
  version     Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdBy   String?  @map("created_by")

  @@index([tenantId], map: "DocumentTemplate_tenantId_idx")
  @@map("document_templates")
}

model GeneratedDocument {
  id              String   @id(map: "GeneratedDocument_pkey") @default(cuid())
  tenantId        String   @map("tenant_id")
  templateId      String   @map("template_id")
  templateVersion Int?     @map("template_version")
  recordId        String?  @map("record_id")
  moduleId        String?  @map("module_id")
  name            String
  url             String?
  status          String   @default("Draft")
  generatedAt     DateTime @default(now()) @map("generated_at")
  generatedBy     String?  @map("generated_by")
  dataSnapshot    Json?    @map("data_snapshot")
  content         String?

  @@index([recordId], map: "GeneratedDocument_recordId_idx")
  @@index([tenantId], map: "GeneratedDocument_tenantId_idx")
  @@map("generated_documents")
}

model Position {
  id             String         @id @default(cuid())
  tenantId       String         @map("tenant_id")
  positionNumber String         @map("position_number")
  title          String
  description    String?
  parentId       String?        @map("parent_id")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  parent         Position?      @relation("PositionToPosition", fields: [parentId], references: [id])
  children       Position[]     @relation("PositionToPosition")
  members        TenantMember[]
  successors     MemberSuccession[]

  @@unique([tenantId, positionNumber])
  @@unique([id, tenantId])
  @@index([tenantId])
  @@map("positions")
}

model PermissionGroup {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  parentGroupId String? @map("parent_group_id")
  name        String
  description String?
  capabilities Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  parentGroup PermissionGroup? @relation("GroupInheritance", fields: [parentGroupId], references: [id])
  childGroups PermissionGroup[] @relation("GroupInheritance")
  members     MemberPermissionGroup[]

  @@index([tenantId])
  @@map("permission_groups")
}

model MemberPermissionGroup {
  tenantId          String   @map("tenant_id")
  memberId          String   @map("member_id")
  permissionGroupId String   @map("permission_group_id")
  assignedAt        DateTime @default(now()) @map("assigned_at")

  tenant             Tenant          @relation(fields: [tenantId], references: [id])
  member            TenantMember    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  permissionGroup   PermissionGroup @relation(fields: [permissionGroupId], references: [id], onDelete: Cascade)

  @@id([memberId, permissionGroupId])
  @@index([tenantId])
  @@map("member_permission_groups")
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  actorId    String   @map("actor_id")
  action     String   
  resourceId String   @map("resource_id")
  oldValue   Json?
  newValue   Json?
  timestamp  DateTime @default(now()) @map("timestamp")

  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, timestamp])
  @@map("audit_logs")
}

enum PartyType {
  PERSON
  ORGANIZATION
}

enum EntityStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  INACTIVE
}

model Party {
  id                 String    @id @default(cuid())
  tenantId           String    @map("tenant_id")
  partyType          PartyType @map("party_type")
  status             EntityStatus @default(DRAFT)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  
  // Agentic Context
  createdBySwarmId   String?   @map("created_by_swarm_id")
  creationContextLog String?   @map("creation_context_log") @db.Text
  
  // Search
  embeddings      Unsupported("vector(768)")? // Requires pgvector extension
  
  tenant             Tenant    @relation(fields: [tenantId], references: [id])
  person             Person?
  organization       Organization?
  sourceRelationships PartyRelationship[] @relation("SourceParty")
  targetRelationships PartyRelationship[] @relation("TargetParty")

  @@index([tenantId])
  @@map("parties")
}

model Person {
  partyId        String   @id @map("party_id")
  firstName      String   @map("first_name")
  lastName       String   @map("last_name")
  dateOfBirth    DateTime? @map("date_of_birth")
  isHumanInLoop Boolean  @default(false) @map("is_human_in_loop")
  
  party          Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@map("persons")
}

model Organization {
  partyId           String   @id @map("party_id")
  legalName         String   @map("legal_name")
  orgStructureType  String   @map("org_structure_type") // Mapped to taxonomy
  incorporationDate DateTime? @map("incorporation_date")
  taxIdentifier     String?  @map("tax_identifier")
  
  party             Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@map("organizations")
}

model PartyRelationship {
  id                  String   @id @default(cuid())
  tenantId            String   @map("tenant_id")
  sourcePartyId       String   @map("source_party_id")
  targetPartyId       String   @map("target_party_id")
  relationshipType    String   @map("relationship_type") // Mapped to taxonomy
  ownershipPercentage Decimal? @map("ownership_percentage") @db.Decimal(5, 2)
  validFrom           DateTime @default(now()) @map("valid_from")
  validTo             DateTime? @map("valid_to")
  
  tenant              Tenant   @relation(fields: [tenantId], references: [id])
  sourceParty         Party    @relation("SourceParty", fields: [sourcePartyId], references: [id], onDelete: Cascade)
  targetParty         Party    @relation("TargetParty", fields: [targetPartyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("party_relationships")
}


model MemberSuccession {
  id         String   @id @default(cuid())
  positionId String   @map("position_id")
  memberId   String   @map("member_id")
  ranking    Int      @default(0)
  
  position   Position     @relation(fields: [positionId], references: [id], onDelete: Cascade)
  member     TenantMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([positionId])
  @@map("member_successions")
}

model EmploymentContract {
  id          String   @id @default(cuid())
  memberId    String   @map("member_id")
  tenantId    String   @map("tenant_id")
  type        String   // e.g. 'Permanent', 'Fixed Term', 'Casual'
  startDate   DateTime @map("start_date")
  endDate     DateTime? @map("end_date")
  status      String   @default("Active")
  documentUrl String?  @map("document_url")
  
  member      TenantMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  remuneration RemunerationDetail[]

  @@index([memberId])
  @@map("employment_contracts")
}

model RemunerationDetail {
  id          String   @id @default(cuid())
  contractId  String   @map("contract_id")
  amount      Float
  currency    String   @default("AUD")
  effectiveDate DateTime @map("effective_date")
  
  contract    EmploymentContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("remuneration_details")
}

model LeaveBalance {
  id        String @id @default(cuid())
  memberId  String @map("member_id")
  type      String // e.g. 'Annual', 'Sick', 'Long Service'
  accrued   Float  @default(0)
  used      Float  @default(0)
  
  member    TenantMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("leave_balances")
}

model LeaveRequest {
  id        String   @id @default(cuid())
  memberId  String   @map("member_id")
  type      String
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  status    String   @default("Pending") // Pending, Approved, Rejected
  reason    String?
  
  member    TenantMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("leave_requests")
}

model Timesheet {
  id          String   @id @default(cuid())
  memberId    String   @map("member_id")
  status      String   @default("Draft")
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  
  member      TenantMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  entries     TimesheetEntry[]

  @@map("timesheets")
}

model TimesheetEntry {
  id          String   @id @default(cuid())
  timesheetId String   @map("timesheet_id")
  date        DateTime
  hours       Float
  description String?
  
  timesheet   Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)

  @@map("timesheet_entries")
}

model Taxonomy {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  category    String   // e.g., "ORG_TYPE", "RELATIONSHIP_TYPE"
  name        String
  slug        String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, category, slug])
  @@index([tenantId])
  @@map("taxonomies")
}
